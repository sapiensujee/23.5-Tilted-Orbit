{
  "$schema": "vscode://schemas/color-theme",
  "name": "23.5° Tilted Orbit",
  "type": "dark",
  "colors": {
    // ── Editor ──────────────────────────────────────────────────
    "editor.background": "#101722",
    "editor.foreground": "#DDE7F0",
    "editorCursor.foreground": "#FFE66D",
    "editor.lineHighlightBackground": "#1A2636",
    "editor.lineHighlightBorder": "#1F2E42",
    "editor.selectionBackground": "#3B587380",
    "editor.inactiveSelectionBackground": "#2A3C4D60",
    "editor.wordHighlightBackground": "#8FD3FF20",
    "editor.wordHighlightStrongBackground": "#8FD3FF30",
    "editor.findMatchBackground": "#FFE66D40",
    "editor.findMatchHighlightBackground": "#FFE66D20",
    "editor.findMatchBorder": "#FFE66D80",
    "editor.rangeHighlightBackground": "#1A263620",
    "editor.hoverHighlightBackground": "#8FD3FF15",
    "editor.foldBackground": "#1A263640",

    "editorIndentGuide.background1": "#263747",
    "editorIndentGuide.activeBackground1": "#8FD3FF",
    "editorRuler.foreground": "#263747",
    "editorBracketMatch.background": "#8FD3FF20",
    "editorBracketMatch.border": "#8FD3FF80",
    "editorBracketHighlight.foreground1": "#FFB86B",
    "editorBracketHighlight.foreground2": "#CDB4FF",
    "editorBracketHighlight.foreground3": "#A7E8BD",
    "editorBracketHighlight.foreground4": "#8FD3FF",
    "editorBracketHighlight.foreground5": "#F7D6E0",
    "editorBracketHighlight.foreground6": "#FFE66D",

    "editorLineNumber.foreground": "#3D5568",
    "editorLineNumber.activeForeground": "#FFE66D",
    "editorWhitespace.foreground": "#263747",
    "editorLink.activeForeground": "#8FD3FF",

    "editorGutter.addedBackground": "#A7E8BD90",
    "editorGutter.modifiedBackground": "#FFB86B90",
    "editorGutter.deletedBackground": "#FF7A9090",

    "editorOverviewRuler.addedForeground": "#A7E8BD80",
    "editorOverviewRuler.modifiedForeground": "#FFB86B80",
    "editorOverviewRuler.deletedForeground": "#FF7A9080",
    "editorOverviewRuler.errorForeground": "#FF7A90",
    "editorOverviewRuler.warningForeground": "#FFB86B",
    "editorOverviewRuler.infoForeground": "#8FD3FF",

    // ── Editor Errors / Warnings ────────────────────────────────
    "editorError.foreground": "#FF7A90",
    "editorWarning.foreground": "#FFB86B",
    "editorInfo.foreground": "#8FD3FF",
    "editorHint.foreground": "#A7E8BD",

    // ── Editor Widget (find/replace, suggest, etc.) ─────────────
    "editorWidget.background": "#151E2B",
    "editorWidget.foreground": "#DDE7F0",
    "editorWidget.border": "#263747",
    "editorSuggestWidget.background": "#151E2B",
    "editorSuggestWidget.border": "#263747",
    "editorSuggestWidget.foreground": "#DDE7F0",
    "editorSuggestWidget.highlightForeground": "#FFE66D",
    "editorSuggestWidget.selectedBackground": "#1C2938",
    "editorSuggestWidget.focusHighlightForeground": "#FFE66D",
    "editorHoverWidget.background": "#151E2B",
    "editorHoverWidget.border": "#263747",

    // ── Diff editor ─────────────────────────────────────────────
    "diffEditor.insertedTextBackground": "#A7E8BD15",
    "diffEditor.removedTextBackground": "#FF7A9015",
    "diffEditor.insertedLineBackground": "#A7E8BD10",
    "diffEditor.removedLineBackground": "#FF7A9010",

    // ── Minimap ─────────────────────────────────────────────────
    "minimap.findMatchHighlight": "#FFE66D60",
    "minimap.selectionHighlight": "#3B587360",
    "minimap.errorHighlight": "#FF7A90",
    "minimap.warningHighlight": "#FFB86B",
    "minimapSlider.background": "#8FD3FF15",
    "minimapSlider.hoverBackground": "#8FD3FF25",
    "minimapSlider.activeBackground": "#8FD3FF35",

    // ── Activity Bar ────────────────────────────────────────────
    "activityBar.background": "#121B28",
    "activityBar.foreground": "#FFE66D",
    "activityBar.inactiveForeground": "#7F9AA8",
    "activityBar.border": "#0D131D",
    "activityBar.activeBorder": "#FFE66D",
    "activityBarBadge.background": "#FFB86B",
    "activityBarBadge.foreground": "#101722",

    // ── Side Bar ────────────────────────────────────────────────
    "sideBar.background": "#151E2B",
    "sideBar.foreground": "#C9D7E3",
    "sideBar.border": "#0D131D",
    "sideBarTitle.foreground": "#FFE66D",
    "sideBarSectionHeader.background": "#1C2938",
    "sideBarSectionHeader.foreground": "#DDE7F0",

    // ── Title Bar ───────────────────────────────────────────────
    "titleBar.activeBackground": "#101722",
    "titleBar.activeForeground": "#DDE7F0",
    "titleBar.inactiveBackground": "#0D131D",
    "titleBar.inactiveForeground": "#7F9AA8",
    "titleBar.border": "#0D131D",

    // ── Tabs ────────────────────────────────────────────────────
    "tab.activeBackground": "#182536",
    "tab.activeForeground": "#FFE66D",
    "tab.activeBorderTop": "#FFE66D",
    "tab.inactiveBackground": "#101722",
    "tab.inactiveForeground": "#8FA7B8",
    "tab.border": "#101722",
    "tab.hoverBackground": "#1A2636",
    "tab.unfocusedActiveBackground": "#151E2B",
    "tab.unfocusedActiveForeground": "#C9D7E3",
    "editorGroupHeader.tabsBackground": "#101722",
    "editorGroupHeader.tabsBorder": "#0D131D",
    "editorGroup.border": "#0D131D",

    // ── Status Bar ──────────────────────────────────────────────
    "statusBar.background": "#1E2D3F",
    "statusBar.foreground": "#DDE7F0",
    "statusBar.border": "#0D131D",
    "statusBar.debuggingBackground": "#FFB86B",
    "statusBar.debuggingForeground": "#101722",
    "statusBar.noFolderBackground": "#151E2B",
    "statusBar.noFolderForeground": "#7F9AA8",
    "statusBarItem.hoverBackground": "#263747",
    "statusBarItem.activeBackground": "#3B5873",
    "statusBarItem.remoteBackground": "#CDB4FF",
    "statusBarItem.remoteForeground": "#101722",
    "statusBarItem.prominentBackground": "#FFB86B30",
    "statusBarItem.prominentHoverBackground": "#FFB86B50",

    // ── Breadcrumb ──────────────────────────────────────────────
    "breadcrumb.foreground": "#7F9AA8",
    "breadcrumb.focusForeground": "#DDE7F0",
    "breadcrumb.activeSelectionForeground": "#FFE66D",
    "breadcrumbPicker.background": "#151E2B",

    // ── Lists and Trees ─────────────────────────────────────────
    "list.activeSelectionBackground": "#1C2938",
    "list.activeSelectionForeground": "#FFE66D",
    "list.inactiveSelectionBackground": "#1A2636",
    "list.inactiveSelectionForeground": "#DDE7F0",
    "list.hoverBackground": "#1A263680",
    "list.hoverForeground": "#DDE7F0",
    "list.focusBackground": "#1C2938",
    "list.focusForeground": "#FFE66D",
    "list.highlightForeground": "#FFE66D",
    "list.errorForeground": "#FF7A90",
    "list.warningForeground": "#FFB86B",
    "tree.indentGuidesStroke": "#263747",

    // ── Scrollbar ───────────────────────────────────────────────
    "scrollbar.shadow": "#00000040",
    "scrollbarSlider.background": "#8FD3FF20",
    "scrollbarSlider.hoverBackground": "#8FD3FF40",
    "scrollbarSlider.activeBackground": "#8FD3FF60",

    // ── Input ───────────────────────────────────────────────────
    "input.background": "#0D131D",
    "input.foreground": "#DDE7F0",
    "input.border": "#263747",
    "input.placeholderForeground": "#7F9AA880",
    "inputOption.activeBorder": "#FFE66D",
    "inputOption.activeBackground": "#FFE66D20",
    "inputOption.activeForeground": "#FFE66D",
    "inputValidation.errorBackground": "#FF7A9030",
    "inputValidation.errorBorder": "#FF7A90",
    "inputValidation.warningBackground": "#FFB86B30",
    "inputValidation.warningBorder": "#FFB86B",
    "inputValidation.infoBackground": "#8FD3FF30",
    "inputValidation.infoBorder": "#8FD3FF",

    // ── Dropdown ────────────────────────────────────────────────
    "dropdown.background": "#0D131D",
    "dropdown.foreground": "#DDE7F0",
    "dropdown.border": "#263747",
    "dropdown.listBackground": "#151E2B",

    // ── Buttons ─────────────────────────────────────────────────
    "button.background": "#FFB86B",
    "button.foreground": "#101722",
    "button.hoverBackground": "#FFC885",
    "button.secondaryBackground": "#263747",
    "button.secondaryForeground": "#DDE7F0",
    "button.secondaryHoverBackground": "#3B5873",

    // ── Badge ───────────────────────────────────────────────────
    "badge.background": "#FFB86B",
    "badge.foreground": "#101722",

    // ── Notifications ───────────────────────────────────────────
    "notifications.background": "#151E2B",
    "notifications.foreground": "#DDE7F0",
    "notifications.border": "#263747",
    "notificationLink.foreground": "#8FD3FF",

    // ── Command Palette / Quick Input ───────────────────────────
    "quickInput.background": "#151E2B",
    "quickInput.foreground": "#DDE7F0",
    "quickInputList.focusBackground": "#1C2938",
    "quickInputList.focusForeground": "#FFE66D",
    "quickInputTitle.background": "#1C2938",

    // ── Panel (terminal, output, problems) ──────────────────────
    "panel.background": "#101722",
    "panel.border": "#263747",
    "panelTitle.activeBorder": "#FFE66D",
    "panelTitle.activeForeground": "#FFE66D",
    "panelTitle.inactiveForeground": "#7F9AA8",

    // ── Terminal ────────────────────────────────────────────────
    "terminal.background": "#101722",
    "terminal.foreground": "#DDE7F0",
    "terminal.selectionBackground": "#3B587360",
    "terminal.ansiBlack": "#1C2938",
    "terminal.ansiBrightBlack": "#3D5568",
    "terminal.ansiRed": "#FF7A90",
    "terminal.ansiBrightRed": "#FF9FB2",
    "terminal.ansiGreen": "#A7E8BD",
    "terminal.ansiBrightGreen": "#C3F0D3",
    "terminal.ansiYellow": "#FFE66D",
    "terminal.ansiBrightYellow": "#FFED99",
    "terminal.ansiBlue": "#8FD3FF",
    "terminal.ansiBrightBlue": "#B3E2FF",
    "terminal.ansiMagenta": "#CDB4FF",
    "terminal.ansiBrightMagenta": "#DDCCFF",
    "terminal.ansiCyan": "#9BE7FF",
    "terminal.ansiBrightCyan": "#C0F0FF",
    "terminal.ansiWhite": "#DDE7F0",
    "terminal.ansiBrightWhite": "#FFFFFF",
    "terminalCursor.foreground": "#FFE66D",

    // ── Git Decoration ──────────────────────────────────────────
    "gitDecoration.addedResourceForeground": "#A7E8BD",
    "gitDecoration.modifiedResourceForeground": "#FFB86B",
    "gitDecoration.deletedResourceForeground": "#FF7A90",
    "gitDecoration.renamedResourceForeground": "#9BE7FF",
    "gitDecoration.untrackedResourceForeground": "#A7E8BD",
    "gitDecoration.ignoredResourceForeground": "#3D5568",
    "gitDecoration.conflictingResourceForeground": "#FFE66D",
    "gitDecoration.stageModifiedResourceForeground": "#FFB86B",
    "gitDecoration.stageDeletedResourceForeground": "#FF7A90",

    // ── Peek View ───────────────────────────────────────────────
    "peekView.border": "#8FD3FF60",
    "peekViewEditor.background": "#0D131D",
    "peekViewEditor.matchHighlightBackground": "#FFE66D30",
    "peekViewResult.background": "#151E2B",
    "peekViewResult.fileForeground": "#DDE7F0",
    "peekViewResult.lineForeground": "#C9D7E3",
    "peekViewResult.matchHighlightBackground": "#FFE66D30",
    "peekViewResult.selectionBackground": "#1C2938",
    "peekViewResult.selectionForeground": "#FFE66D",
    "peekViewTitle.background": "#1C2938",
    "peekViewTitleLabel.foreground": "#FFE66D",
    "peekViewTitleDescription.foreground": "#7F9AA8",

    // ── Merge ───────────────────────────────────────────────────
    "merge.currentHeaderBackground": "#A7E8BD40",
    "merge.currentContentBackground": "#A7E8BD15",
    "merge.incomingHeaderBackground": "#8FD3FF40",
    "merge.incomingContentBackground": "#8FD3FF15",

    // ── Debug ───────────────────────────────────────────────────
    "debugToolBar.background": "#1C2938",
    "debugToolBar.border": "#263747",
    "debugIcon.breakpointForeground": "#FF7A90",
    "debugIcon.breakpointDisabledForeground": "#7F9AA8",
    "debugIcon.startForeground": "#A7E8BD",
    "debugIcon.pauseForeground": "#FFE66D",
    "debugIcon.stopForeground": "#FF7A90",
    "debugIcon.restartForeground": "#A7E8BD",
    "debugIcon.stepOverForeground": "#8FD3FF",
    "debugIcon.stepIntoForeground": "#8FD3FF",
    "debugIcon.stepOutForeground": "#8FD3FF",
    "debugIcon.continueForeground": "#A7E8BD",
    "debugConsole.infoForeground": "#8FD3FF",
    "debugConsole.warningForeground": "#FFB86B",
    "debugConsole.errorForeground": "#FF7A90",

    // ── Welcome page ────────────────────────────────────────────
    "welcomePage.background": "#101722",
    "walkThrough.embeddedEditorBackground": "#0D131D",

    // ── Settings ────────────────────────────────────────────────
    "settings.headerForeground": "#FFE66D",
    "settings.modifiedItemIndicator": "#FFB86B",
    "settings.dropdownBackground": "#0D131D",
    "settings.checkboxBackground": "#0D131D",
    "settings.textInputBackground": "#0D131D",
    "settings.numberInputBackground": "#0D131D",

    // ── Focus ───────────────────────────────────────────────────
    "focusBorder": "#8FD3FF60",
    "foreground": "#DDE7F0",
    "selection.background": "#3B587380",
    "widget.shadow": "#00000040",
    "progressBar.background": "#FFE66D",
    "textLink.foreground": "#8FD3FF",
    "textLink.activeForeground": "#B3E2FF",
    "icon.foreground": "#C9D7E3",
    "descriptionForeground": "#7F9AA8"
  },

  "tokenColors": [
    // ── Comments ────────────────────────────────────────────────
    {
      "name": "Comments — shy inner thoughts",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7F9AA8",
        "fontStyle": "italic"
      }
    },

    // ── Keywords & Storage ──────────────────────────────────────
    {
      "name": "Keywords — Sun warmth",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FFB86B"
      }
    },
    {
      "name": "Keyword operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#B6C9D8"
      }
    },

    // ── Strings ─────────────────────────────────────────────────
    {
      "name": "Strings — Earth / garden green",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple"
      ],
      "settings": {
        "foreground": "#A7E8BD"
      }
    },
    {
      "name": "String interpolation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#FFB86B"
      }
    },
    {
      "name": "String escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#9BE7FF"
      }
    },

    // ── Constants ───────────────────────────────────────────────
    {
      "name": "Constants — sunlight",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#FFE66D"
      }
    },

    // ── Variables ───────────────────────────────────────────────
    {
      "name": "Variables — soft romantic pink",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "support.variable"
      ],
      "settings": {
        "foreground": "#F7D6E0"
      }
    },
    {
      "name": "Variable parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F7D6E0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable this / self",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#FFB86B",
        "fontStyle": "italic"
      }
    },

    // ── Functions ───────────────────────────────────────────────
    {
      "name": "Functions — clear sky blue",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#8FD3FF"
      }
    },

    // ── Classes / Types ─────────────────────────────────────────
    {
      "name": "Classes & Types — Luna / space lavender",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.module",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#CDB4FF"
      }
    },
    {
      "name": "Interfaces / type parameters",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.parameter"
      ],
      "settings": {
        "foreground": "#CDB4FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#FFB86B",
        "fontStyle": "italic"
      }
    },

    // ── Tags (HTML/JSX/XML) ─────────────────────────────────────
    {
      "name": "HTML/JSX Tags — warm blush",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#FF9FB2"
      }
    },
    {
      "name": "Tag attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FFB86B",
        "fontStyle": "italic"
      }
    },

    // ── CSS ─────────────────────────────────────────────────────
    {
      "name": "CSS property names",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#8FD3FF"
      }
    },
    {
      "name": "CSS property values",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#F7D6E0"
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#FFE66D"
      }
    },
    {
      "name": "CSS pseudo-classes & pseudo-elements",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#CDB4FF"
      }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit.css",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#FFE66D"
      }
    },

    // ── JSON ────────────────────────────────────────────────────
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json",
        "string.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#8FD3FF"
      }
    },

    // ── Markdown ────────────────────────────────────────────────
    {
      "name": "Markdown headings",
      "scope": [
        "heading.1.markdown entity.name",
        "heading.2.markdown entity.name",
        "heading.3.markdown entity.name",
        "heading.4.markdown entity.name",
        "heading.5.markdown entity.name",
        "heading.6.markdown entity.name",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#FFE66D",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FFB86B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#F7D6E0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#A7E8BD"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#8FD3FF"
      }
    },

    // ── Punctuation ─────────────────────────────────────────────
    {
      "name": "Punctuation — soft mist",
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter",
        "punctuation.definition.block",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#B6C9D8"
      }
    },

    // ── Support / Built-ins ─────────────────────────────────────
    {
      "name": "Built-in constants",
      "scope": [
        "support.constant",
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#FFE66D"
      }
    },
    {
      "name": "Property access / object keys",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#9BE7FF"
      }
    },

    // ── Regex ───────────────────────────────────────────────────
    {
      "name": "Regular expression",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#FF9FB2"
      }
    },

    // ── Invalid ─────────────────────────────────────────────────
    {
      "name": "Invalid — romcom panic",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#101722",
        "background": "#FF7A90"
      }
    },
    {
      "name": "Invalid deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#101722",
        "background": "#FFB86B"
      }
    }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#8FD3FF",
    "function.declaration": "#8FD3FF",
    "method": "#8FD3FF",
    "method.declaration": "#8FD3FF",
    "class": "#CDB4FF",
    "class.declaration": { "foreground": "#CDB4FF", "bold": true },
    "interface": { "foreground": "#CDB4FF", "italic": true },
    "interface.declaration": { "foreground": "#CDB4FF", "italic": true, "bold": true },
    "enum": "#FFE66D",
    "enumMember": "#FFE66D",
    "struct": "#CDB4FF",
    "type": "#CDB4FF",
    "typeParameter": { "foreground": "#CDB4FF", "italic": true },
    "namespace": "#CDB4FF",
    "variable": "#F7D6E0",
